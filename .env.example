# Database (Docker Postgres on port 5433 locally; Neon URL in production)
DATABASE_URL=postgresql://rihlatech:rihlatech@localhost:5433/rihlatech

# Auth
JWT_SECRET=change-me-to-a-long-random-string

# CORS — comma-separated frontend origins (add your Vercel URL in production)
CORS_ORIGINS=http://localhost:5173,http://localhost:5174

# Frontend API base (production only — set in Vercel, baked in at build time)
# VITE_API_BASE_URL=https://rihlatech-api.onrender.com/api

# LLM — set LLM_PROVIDER to force one backend (auto picks first available key)
LLM_PROVIDER=auto

# Google Gemini (https://aistudio.google.com/apikey)
GEMINI_API_KEY=
GEMINI_MODEL=gemini-2.5-flash

# OpenRouter (https://openrouter.ai/keys)
OPENROUTER_API_KEY=
OPENROUTER_MODEL=openai/gpt-4o-mini
OPENROUTER_SITE_URL=http://localhost:5173
OPENROUTER_APP_NAME=RihlaTech

# Direct OpenAI (optional fallback)
OPENAI_API_KEY=

# Mapbox — geocoding (backend) + map tiles (frontend public token)
# https://account.mapbox.com/access-tokens/
MAPBOX_ACCESS_TOKEN=
VITE_MAPBOX_ACCESS_TOKEN=

# Duffel — flight search sandbox (https://duffel.com/dashboard)
DUFFEL_ACCESS_TOKEN=
